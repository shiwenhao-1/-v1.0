    (proto / "requirements.txt").write_text("fastapi>=0.115.0\nuvicorn[standard]>=0.30.0\npydantic>=2.7.0\n", encoding="utf-8")
    (proto / "project_spec.json").write_text(json.dumps(spec, ensure_ascii=False, indent=2), encoding="utf-8")

    (proto / "README.md").write_text(
        dedent(
            f"""
