BLOCKED_KEYWORDS = [
    # 这些不是“审查”，只是避免系统生成明显不适合未成年人或高风险方向的执行方案。
    "weapon", "gun", "ammo", "knife", "explosive", "drugs", "gambling", "casino",
    "porn", "adult content", "vape", "nicotine", "thc", "marijuana", "hacking", "phishing",
    "枪", "弹药", "刀", "爆炸", "毒品", "赌博", "赌场", "色情", "成人内容", "电子烟", "尼古丁",
    "大麻", "钓鱼网站", "盗号",
]


def validate_idea(text: str) -> tuple[bool, str]:
    lowered = text.lower()
    for keyword in BLOCKED_KEYWORDS:
        if keyword.lower() in lowered:
            return False, "这个项目方向可能涉及高风险或不适合未成年人的内容，系统不会生成执行方案。请换成学习、效率、生活服务、公益、创作或开发工具类方向。"
    return True, "ok"

