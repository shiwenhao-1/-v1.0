import os
from dataclasses import dataclass


@dataclass
class LLMResult:
    text: str
    mode: str


class LLMClient:
    """Small wrapper around OpenAI Responses API with an offline fallback.

    The system runs without an API key. With OPENAI_API_KEY set, it calls OpenAI.
    """

    def __init__(self, model: str) -> None:
        self.model = model
        self.api_key = os.getenv("OPENAI_API_KEY")
        self._client = None
        if self.api_key:
            try:
                from openai import OpenAI

                self._client = OpenAI(api_key=self.api_key)
            except Exception:
                self._client = None

    @property
    def mode(self) -> str:
        return "ai" if self._client else "offline-template"

    def complete(self, *, system: str, user: str, fallback: str) -> LLMResult:
        if not self._client:
            return LLMResult(text=fallback.strip(), mode=self.mode)

        try:
            response = self._client.responses.create(
                model=self.model,
                input=[
                    {"role": "system", "content": system},
                    {"role": "user", "content": user},
                ],
            )
            output_text = getattr(response, "output_text", "") or ""
            if not output_text.strip():
                return LLMResult(text=fallback.strip(), mode="ai-empty-fallback")
            return LLMResult(text=output_text.strip(), mode=self.mode)
        except Exception as exc:  # keep the app runnable even when API fails
            return LLMResult(
                text=(fallback.strip() + f"\n\n> AI 调用失败，已使用离线模板。错误：{type(exc).__name__}: {exc}"),
                mode="ai-error-fallback",
            )

