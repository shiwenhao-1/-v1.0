import sqlite3
from pathlib import Path
from typing import Any


class Store:
    def __init__(self, db_path: Path) -> None:
        self.db_path = db_path
        self.db_path.parent.mkdir(parents=True, exist_ok=True)
        self.init_db()

    def connect(self) -> sqlite3.Connection:
        conn = sqlite3.connect(self.db_path)
        conn.row_factory = sqlite3.Row
        return conn

    def init_db(self) -> None:
        with self.connect() as conn:
            conn.execute(
                """
                CREATE TABLE IF NOT EXISTS runs (
                    id TEXT PRIMARY KEY,
                    title TEXT NOT NULL,
                    idea TEXT NOT NULL,
                    created_at TEXT NOT NULL,
                    mode TEXT NOT NULL,
                    summary TEXT NOT NULL,
                    output_dir TEXT NOT NULL
                )
                """
            )
            conn.commit()

    def insert_run(self, *, id: str, title: str, idea: str, created_at: str, mode: str, summary: str, output_dir: Path) -> None:
        with self.connect() as conn:
            conn.execute(
                """
                INSERT INTO runs (id, title, idea, created_at, mode, summary, output_dir)
                VALUES (?, ?, ?, ?, ?, ?, ?)
                """,
                (id, title, idea, created_at, mode, summary, str(output_dir)),
            )
            conn.commit()

    def list_runs(self) -> list[dict[str, Any]]:
        with self.connect() as conn:
            rows = conn.execute("SELECT * FROM runs ORDER BY created_at DESC").fetchall()
        return [dict(row) for row in rows]

    def get_run(self, run_id: str) -> dict[str, Any] | None:
        with self.connect() as conn:
            row = conn.execute("SELECT * FROM runs WHERE id = ?", (run_id,)).fetchone()
        return dict(row) if row else None

from __future__ import annotations

import json
import shutil
from datetime import datetime, timezone
from pathlib import Path
from uuid import uuid4

from .agents import AGENT_CLASSES, ProjectContext
from .config import settings
from .llm import LLMClient
from .models import IncubationRequest, IncubationSummary
from .prototype import generate_prototype, make_title, slugify
from .safety import validate_idea
from .store import Store


class ProjectIncubator:
    def __init__(self, store: Store | None = None, workspace_dir: Path | None = None, llm: LLMClient | None = None) -> None:
        self.store = store or Store(settings.database_path)
        self.workspace_dir = workspace_dir or settings.workspace_dir
        self.workspace_dir.mkdir(parents=True, exist_ok=True)
        self.llm = llm or LLMClient(settings.openai_model)

    def incubate(self, req: IncubationRequest) -> IncubationSummary:
        ok, message = validate_idea(" ".join([req.idea, req.target_users, req.constraints]))
        if not ok:
            raise ValueError(message)

        title = make_title(req.idea)
        run_id = f"{slugify(title)}-{uuid4().hex[:8]}"
        created_at = datetime.now(timezone.utc).isoformat()
        run_dir = self.workspace_dir / run_id
        run_dir.mkdir(parents=True, exist_ok=True)

        context = ProjectContext(
            idea=req.idea,
            target_users=req.target_users,
            platform=req.platform,
            constraints=req.constraints,
        )

        previous: dict[str, str] = {}
        modes: list[str] = []
        for agent_cls in AGENT_CLASSES:
            agent = agent_cls(self.llm)
            result = agent.run(context, previous)
            previous[agent.name] = result.text
            modes.append(result.mode)
            (run_dir / agent.name).write_text(result.text.strip() + "\n", encoding="utf-8")

        if req.generate_prototype:
            generate_prototype(run_dir, context, previous)

        summary = self._build_summary(title, context, previous)
        (run_dir / "README.md").write_text(summary + "\n", encoding="utf-8")
        (run_dir / "project_spec.json").write_text(
            json.dumps(
                {
                    "id": run_id,
                    "title": title,
                    "idea": req.idea,
                    "target_users": req.target_users,
                    "platform": req.platform,
                    "constraints": req.constraints,
                    "created_at": created_at,
                    "mode": self._mode_label(modes),
                    "artifacts": self._artifacts(run_dir),
                },
                ensure_ascii=False,
                indent=2,
            ),
            encoding="utf-8",
        )

        zip_path = self._zip_run(run_dir)
        mode = self._mode_label(modes)
        self.store.insert_run(
            id=run_id,
            title=title,
            idea=req.idea,
            created_at=created_at,
            mode=mode,
            summary=summary.split("\n\n", 1)[0].replace("# ", ""),
            output_dir=run_dir,
        )

        artifacts = self._artifacts(run_dir)
        if zip_path.name not in artifacts:
            artifacts.append(zip_path.name)
        return IncubationSummary(
            id=run_id,
            title=title,
            created_at=created_at,
            mode=mode,
            summary=summary,
            artifacts=artifacts,
            download_url=f"/api/runs/{run_id}/download",
        )

    def get_download_path(self, run_id: str) -> Path | None:
        row = self.store.get_run(run_id)
        if not row:
            return None
        run_dir = Path(row["output_dir"])
        zip_path = run_dir.with_suffix(".zip")
        return zip_path if zip_path.exists() else None

    def get_run_detail(self, run_id: str) -> dict | None:
        row = self.store.get_run(run_id)
        if not row:
            return None
        run_dir = Path(row["output_dir"])
        row["artifacts"] = self._artifacts(run_dir) if run_dir.exists() else []
        return row

    def _zip_run(self, run_dir: Path) -> Path:
        zip_path = run_dir.with_suffix(".zip")
        if zip_path.exists():
            zip_path.unlink()
        shutil.make_archive(str(run_dir), "zip", root_dir=run_dir)
        return zip_path

    def _artifacts(self, run_dir: Path) -> list[str]:
        files = []
        for path in sorted(run_dir.rglob("*")):
            if path.is_file():
                files.append(str(path.relative_to(run_dir)))
        return files

    def _mode_label(self, modes: list[str]) -> str:
        if any(m == "ai" for m in modes):
            return "ai"
        if any("error" in m for m in modes):
            return "ai-error-fallback"
        return "offline-template"

    def _build_summary(self, title: str, context: ProjectContext, docs: dict[str, str]) -> str:
        return (
            f"# {title}\n\n"
            f"项目想法：{context.idea}\n\n"
            "## 已生成产物\n"
            "- 产品简报\n"
            "- PRD 产品需求文档\n"
            "- 技术架构\n"
            "- 路线图\n"
            "- 开发任务清单\n"
            "- 测试计划\n"
            "- 项目展示文案\n"
            "- 可运行 MVP 原型 prototype/\n\n"
            "## 建议下一步\n"
            "1. 先阅读 01_PRODUCT_BRIEF.md 和 02_PRD.md，确认 MVP 范围。\n"
            "2. 运行 prototype/，把核心功能改成你的真实业务。\n"
            "3. 按 05_TASKS.md 从 P0 开始开发。\n"
            "4. 用 06_TEST_PLAN.md 做演示前检查。\n"
        )

from __future__ import annotations

from pathlib import Path

from fastapi import FastAPI, HTTPException
from fastapi.responses import FileResponse, HTMLResponse

from .config import settings
from .models import IncubationRequest, IncubationSummary, RunItem
from .orchestrator import ProjectIncubator
from .store import Store

app = FastAPI(title=settings.app_name)
store = Store(settings.database_path)
incubator = ProjectIncubator(store=store, workspace_dir=settings.workspace_dir)


@app.get("/", response_class=HTMLResponse)
def home() -> str:
    html_path = Path(__file__).parent / "static" / "index.html"
    return html_path.read_text(encoding="utf-8")


@app.post("/api/incubate", response_model=IncubationSummary)
def incubate(req: IncubationRequest) -> IncubationSummary:
    try:
        return incubator.incubate(req)
    except ValueError as exc:
        raise HTTPException(status_code=400, detail=str(exc)) from exc


@app.get("/api/runs", response_model=list[RunItem])
def list_runs() -> list[RunItem]:
    rows = store.list_runs()
    items: list[RunItem] = []
    for row in rows:
        output_dir = Path(row["output_dir"])
        count = len([p for p in output_dir.rglob("*") if p.is_file()]) if output_dir.exists() else 0
        items.append(
            RunItem(
                id=row["id"],
                title=row["title"],
                created_at=row["created_at"],
                mode=row["mode"],
                summary=row["summary"],
                artifact_count=count,
            )
        )
    return items


@app.get("/api/runs/{run_id}")
def get_run(run_id: str) -> dict:
    detail = incubator.get_run_detail(run_id)
    if not detail:
        raise HTTPException(status_code=404, detail="Run not found")
    return detail


@app.get("/api/runs/{run_id}/download")
def download_run(run_id: str) -> FileResponse:
    zip_path = incubator.get_download_path(run_id)
    if not zip_path:
        raise HTTPException(status_code=404, detail="Download not found")
    return FileResponse(path=zip_path, filename=zip_path.name, media_type="application/zip")
