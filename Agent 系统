@dataclass
class ProjectContext:
    idea: str
    target_users: str
    platform: str
    constraints: str

    def as_text(self) -> str:
        return dedent(
            f"""
            项目想法：{self.idea}
            目标用户：{self.target_users or '未指定，请自行合理假设'}
            目标平台：{self.platform}
            限制条件：{self.constraints or '无特殊限制'}
            """
        ).strip()


class BaseAgent:
    name = "BaseAgent"
    role = "你是一个严谨的创业项目孵化 Agent。"

    def __init__(self, llm: LLMClient) -> None:
        self.llm = llm

    def run(self, context: ProjectContext, previous: dict[str, str]) -> LLMResult:
        raise NotImplementedError

    def _complete(self, context: ProjectContext, previous: dict[str, str], task: str, fallback: str) -> LLMResult:
        prev_text = "\n\n".join(f"## {k}\n{v}" for k, v in previous.items()) or "无"
        user = dedent(
            f"""
            你需要为一个个人项目孵化系统输出一个可直接保存为 Markdown 的文档。

            # 项目背景
            {context.as_text()}

            # 已有上游 Agent 输出
            {prev_text}

            # 当前任务
            {task}
            """
        ).strip()
        return self.llm.complete(system=self.role, user=user, fallback=fallback)


class ProductAnalystAgent(BaseAgent):
    name = "01_PRODUCT_BRIEF.md"
    role = "你是产品分析 Agent，擅长从模糊想法里提炼用户、痛点、价值主张和 MVP 边界。"

    def run(self, context: ProjectContext, previous: dict[str, str]) -> LLMResult:
        fallback = dedent(
            f"""
            # 产品简报

            ## 一句话概述
            基于“{context.idea}”构建一个面向 {context.target_users or '早期个人用户'} 的 {context.platform} MVP，先解决一个高频、明确、可验证的小痛点。

            ## 核心用户
            - 第一批用户：{context.target_users or '有明确效率/学习/创作需求的个人用户'}
            - 使用场景：用户有一个想法，但缺少从需求、设计、任务拆解到原型落地的系统流程。
            - 用户目标：用更短时间得到可展示、可测试、可迭代的 MVP。

            ## 核心痛点
            1. 想法很多，但不知道第一版应该做哪些功能。
            2. 不会把想法转成 PRD、技术方案、任务清单和测试计划。
            3. 个人项目容易卡在规划阶段，缺少可执行的下一步。

            ## 价值主张
            系统把“想法 → 产品定义 → 技术方案 → 开发任务 → 测试计划 → 演示文案”串成一条流水线，帮助用户在 1 天内完成通常需要数天的项目前期准备。

            ## MVP 边界
            第一版只做：想法输入、Agent 协作生成文档、生成可运行原型、导出项目包。不做复杂团队协同、支付、权限系统和大型部署平台。

            ## 成功指标
            - 用户能在 10 分钟内完成一次项目孵化。
            - 输出至少包含 PRD、架构、任务、测试、Pitch 和可运行原型。
            - 生成内容人工修改比例低于 40%。
            """
        )
        task = "输出产品简报：一句话概述、核心用户、痛点、价值主张、MVP 边界、成功指标。不要空泛，要可落地。"
        return self._complete(context, previous, task, fallback)


