def slugify(text: str, fallback: str = "mvp") -> str:
    text = text.lower().strip()
    text = re.sub(r"[^a-z0-9\u4e00-\u9fff]+", "-", text)
    text = re.sub(r"-+", "-", text).strip("-")
    return text[:40] or fallback


def make_title(idea: str) -> str:
    clean = re.sub(r"\s+", " ", idea).strip()
    return clean[:28] + ("..." if len(clean) > 28 else "")


def generate_prototype(project_dir: Path, context: ProjectContext, docs: dict[str, str]) -> Path:
    """Create a tiny but runnable FastAPI MVP prototype for the user's idea."""
    proto = project_dir / "prototype"
    static = proto / "static"
    static.mkdir(parents=True, exist_ok=True)

    title = make_title(context.idea)
    spec = {
        "title": title,
        "idea": context.idea,
        "target_users": context.target_users or "早期个人用户",
        "platform": context.platform,
        "constraints": context.constraints,
        "features": [
